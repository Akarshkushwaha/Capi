COGNEE_API_URL=your_cognee_cloud_api_url
COGNEE_API_KEY=your_cognee_api_key

# LLM Provider — we use Groq (free tier, fast)
LLM_PROVIDER=groq
LLM_API_KEY=your_groq_api_key_gsk_...
LLM_MODEL=groq/gpt-oss-20b

# If you want to use OpenAI instead, comment above and uncomment below:
# LLM_PROVIDER=openai
# LLM_API_KEY=your_openai_key_here
# LLM_MODEL=openai/gpt-4o-mini
