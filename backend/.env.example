COGNEE_API_URL=your_cognee_cloud_api_url
COGNEE_API_KEY=your_cognee_api_key

# LLM — Groq via "custom" provider
# NOTE: LLM_PROVIDER must be "custom" (Cognee's enum doesn't have "groq")
# NOTE: LLM_MODEL must be prefixed with "groq/" so litellm routes correctly
LLM_PROVIDER=custom
LLM_MODEL=groq/llama-3.3-70b-versatile
LLM_API_KEY=your_groq_api_key_gsk_...
LLM_ENDPOINT=https://api.groq.com/openai/v1

# Embeddings — Fastembed (free, local, no API key needed)
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# Skip Cognee's preflight connection test (times out with custom/Groq endpoint)
COGNEE_SKIP_CONNECTION_TEST=true
